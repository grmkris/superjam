{
  "name": "@superjam/contracts",
  "private": true,
  "type": "module",
  "exports": {
    "./abi/stake-slash": "./generated/stake-slash.abi.ts",
    "./abi/simple-yield-vault": "./generated/simple-yield-vault.abi.ts"
  },
  "scripts": {
    "compile": "forge build",
    "gen": "bun run scripts/gen-abi.ts",
    "build:contracts": "forge build && bun run scripts/gen-abi.ts",
    "test:forge": "forge test -vvv",
    "typecheck": "tsc --noEmit",
    "deploy:arc": "forge script script/Deploy.s.sol:Deploy --rpc-url $ARC_RPC_URL --private-key $SERVER_WALLET_PRIVATE_KEY --broadcast"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
