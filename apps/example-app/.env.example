# SuperJam identity — the platform injects these at deploy (the builder sets them
# automatically; for a hand-deployed app, copy from the SuperJam dev portal).
SUPERJAM_JWKS_URL=https://superjam.fun/.well-known/jwks.json
SUPERJAM_ISSUER=https://superjam.fun
SUPERJAM_APP_ID=                                   # this app's id = token audience

# Who may iframe this app (the SuperJam host origins).
SUPERJAM_FRAME_ANCESTORS=https://superjam.fun https://dev.superjam.fun

# The app's OWN database (Neon). Leave unset to use the in-memory fallback.
DATABASE_URL=

# Optional: override the manifest homeUrl (defaults to the Vercel prod URL).
SUPERJAM_HOME_URL=
