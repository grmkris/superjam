# SuperJam env manifest (§1). Copy to .env and fill. Core rows REQUIRED at
# kickoff (no mock fallbacks, §0.2); stretch rows optional. Web NEXT_PUBLIC_*
# are passed as BUILD ARGS on Railway, not runtime vars (§18).

# --- identity / env ---
APP_ENV=local                       # local | dev | prod (server, no default)

# --- data ---
DATABASE_URL=postgres://superjam:superjam@localhost:47432/superjam
S3_ENDPOINT=http://localhost:47900
S3_BUCKET=superjam
S3_ACCESS_KEY=superjam
S3_SECRET_KEY=superjam-secret
S3_REGION=us-east-1

# --- AI ---
GOOGLE_GENERATIVE_AI_API_KEY=       # aistudio.google.com — PRIMARY refine (Gemini)
ANTHROPIC_API_KEY=                  # in-app sdk.ai (haiku) + oneshot fallback
FAL_KEY=                            # generate_image / sdk.ai.image (optional)

# --- builder (dev-box VPS) ---
BUILDER_MODE=remote                 # remote | agent | oneshot (§5.1)
BUILDER_URL=https://builder.superjam.fun
BUILDER_TOKEN=                      # ~/.config/turbojam/builder.env

# --- auth (Dynamic) ---
DYNAMIC_ENVIRONMENT_ID=             # Dynamic dashboard (confirm-popup OFF)
DYNAMIC_API_TOKEN=                  # agent server wallet (TSS-MPC signer) + delegated client api key
DYNAMIC_DELEGATION_PRIVATE_KEY=     # RSA PKCS8 PEM — decrypts delegated key shares (public key → Dynamic dashboard)
DYNAMIC_WEBHOOK_SECRET=             # HMAC secret for /api/webhooks/dynamic/delegation (x-dynamic-signature-256)

# --- app identity token (§1) — platform mints ES256 tokens external apps verify
# generate: openssl ecparam -genkey -name prime256v1 -noout -out k.pem
#           openssl pkcs8 -topk8 -nocrypt -in k.pem -out priv.pem   (→ PRIVATE)
#           openssl ec -in k.pem -pubout -out pub.pem               (→ PUBLIC)
APP_JWT_PRIVATE_KEY=                # ES256 PKCS8 PEM (server-only secret)
APP_JWT_PUBLIC_KEY=                 # ES256 SPKI PEM (served at /.well-known/jwks.json)
APP_JWT_KID=sj-app                  # stable key id (rotation)

# --- World ID 4.0 (managed RP) ---
WORLD_APP_ID=            # app_… (Dev Portal) → the IDKit widget
WORLD_RP_ID=             # rp_… → /api/v4/{proof-context,verify}/{rp_id} + rp_context.rp_id
WORLD_RP_SIGNING_KEY=    # RP ECDSA key (rotate via the Dev Portal/MCP) — backend signs rp_context
WORLD_ACTION=superjam-human  # the v4 action all human gates verify against (one per app — re-namespacing it resets World's per-person nullifier ledger)
WORLD_ENVIRONMENT=staging # staging → World ID Simulator (dev); production for the live demo

# --- ENS / onchain ---
# The sole privileged signer (relay/escrow/ENS/pots/topup). A Dynamic TSS server
# wallet (DYNAMIC_API_TOKEN) is preferred; this raw key drives the same signer.
SERVER_WALLET_PRIVATE_KEY=          # 0x… funded on Arc (USDC gas) + Base Sepolia/Sepolia ETH
STAKE_SLASH_ADDRESS=                # deployed StakeSlash escrow (Arc) — see packages/contracts/deployments
CCTP_ESCROW_HOOK_ADDRESS=           # deployed CctpEscrowHook (Arc) — cross-chain stake top-up (Circle #2)
ENS_L2_REGISTRY=                    # Durin L2Registry on Base Sepolia
ENS_PARENT_NODE=                    # namehash("superjam.eth") on Sepolia
ERC8004_REGISTRY=                   # ERC-8004 registry (Base Sepolia / Sepolia)
TREASURY_ADDRESS=                   # platform treasury (publish fees) — defaults to the server wallet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ARC_RPC_URL=https://rpc.testnet.arc.network

# --- privacy rail (Unlink + Circle, stretch/gated) ---
UNLINK_API_KEY=                     # confidential tips on Arc testnet (§15)
UNLINK_APP_ID=
CIRCLE_GATEWAY_API_KEY=             # payX402 leg (gated, §9)
ARC_PAYER_EOA_KEY=                  # funded plain payer EOA on Arc testnet

# --- logging ---
LOG_LEVEL=info

# --- web build args (NEXT_PUBLIC_*) ---
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
NEXT_PUBLIC_WORLD_APP_ID=
